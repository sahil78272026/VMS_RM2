{
  "cli": {
    "version": ">= 20.1.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },

    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://vms-rm2-1.onrender.com/api/v1",
        "EXPO_PUBLIC_FRONTEND_URL": "https://vmsrm2.netlify.app"
      },
      "android":{
        "buildType":"apk"
      }
      },

    "production": {
      "autoIncrement": true,
      "android":{
        "buildType":"app-bundle"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
